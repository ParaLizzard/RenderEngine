#version 460
layout(local_size_x = 256) in;
layout(set = 1, binding = 9) buffer BinningMeta {
    uint counters[256];
    uint offsets[256];
    uint totalPixels;
} meta;

void main() {
    uint sum = 0;
    for (uint i = 0; i < 256; i++) {
        meta.offsets[i] = sum;
        sum += meta.counters[i];
    }
    meta.totalPixels = sum;
}